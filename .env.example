# Infrastructure configuration is environment-only. OpenHug never persists these values.
OPENHUG_DATABASE_URL=postgres://openhug:openhug@localhost:5432/openhug
OPENHUG_BIND=127.0.0.1:3000
OPENHUG_PUBLIC_URL=http://localhost:3000
# Required for first-run setup when onboarding from a non-loopback address.
# Generate with: openssl rand -base64 32
# OPENHUG_SETUP_TOKEN=...

# local | s3 | minio | digitalocean | hetzner
OPENHUG_STORAGE_DRIVER=local
OPENHUG_STORAGE_LOCAL_PATH=./data

# Required for S3-compatible drivers. Values shown are examples only.
# OPENHUG_STORAGE_BUCKET=openhug
# OPENHUG_STORAGE_REGION=us-east-1
# OPENHUG_STORAGE_ENDPOINT=https://s3.example.com
# OPENHUG_STORAGE_ACCESS_KEY=...
# OPENHUG_STORAGE_SECRET_KEY=...
# OPENHUG_STORAGE_VIRTUAL_HOSTED_STYLE=false

RUST_LOG=openhug_server=info,tower_http=info

